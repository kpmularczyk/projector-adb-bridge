[Unit]
Description=Projector ADB Bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=amanita
WorkingDirectory=/opt/projector-adb-bridge
ExecStart=/opt/projector-adb-bridge/venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target